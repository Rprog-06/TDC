# Email Configuration
# For development/demo: use Ethereal (https://ethereal.email - free fake SMTP)
# For production: use Gmail, SendGrid, or your email provider

EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_ethereal_email@ethereal.email
EMAIL_PASSWORD=your_ethereal_password
EMAIL_FROM=noreply@thedatecrew.com

# Gemini API (for AI reasons only, not for every email)
GEMINI_API_KEY=your_gemini_api_key_here

# Environment
NODE_ENV=development
